# ============================================================
# Kalamundi — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer .env dans git
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
# SUPABASE_SERVICE_KEY -> jamais côté client, requis par les Pages Functions serveur
# (fapshi-webhook.js, fapshi-pay.js, payout-occasion.js) pour écrire en base
# avec la clé de service (contourne le RLS).
SUPABASE_SERVICE_KEY=eyJxxxxx

# --- Fapshi (Mobile Money Cameroun) ---
# Requis côté Pages Functions serveur (fapshi-pay.js, payout-occasion.js).
FAPSHI_API_USER=xxxxx
FAPSHI_API_KEY=xxxxx
# Secret partagé optionnel, à envoyer dans l'en-tête x-kalamundi-secret
# pour authentifier le webhook Fapshi (fapshi-webhook.js).
FAPSHI_WEBHOOK_SECRET=xxxxx
# Secret partagé pour déclencher /api/payout-occasion (versement vendeurs
# occasion) depuis le cron kalamundi-cron — à configurer aussi comme
# secret du Worker cron (wrangler secret put PAYOUT_TASK_SECRET).
PAYOUT_TASK_SECRET=xxxxx

# --- Google Cloud Translation ---
GOOGLE_TRANSLATE_API_KEY=xxxxx

# --- Stripe (paiements internationaux) ---
STRIPE_PUBLIC_KEY=pk_live_xxxxx
# STRIPE_SECRET_KEY -> jamais côté client, passe par Supabase Edge Function

# --- CinetPay (Mobile Money Afrique francophone) ---
CINETPAY_API_KEY=xxxxx
CINETPAY_SITE_ID=xxxxx

# --- Flutterwave (Mobile Money Afrique anglophone) ---
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_xxxxx

# --- Cloudflare Pages (déploiement) ---
CLOUDFLARE_ACCOUNT_ID=xxxxx
CLOUDFLARE_API_TOKEN=xxxxx

# --- OpenTimestamps (horodatage blockchain — gratuit) ---
# Aucune clé requise, appel via Edge Function

# --- Notifications publication ---
ONESIGNAL_APP_ID=xxxxx
ONESIGNAL_REST_API_KEY=xxxxx
RESEND_API_KEY=re_xxxxx
NOTIFICATION_FROM_EMAIL="Kalamundi <notifications@kalamundi.com>"
KALAMUNDI_BASE_URL=https://kalamundi.com
